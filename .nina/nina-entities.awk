function replace_entities(s,    out, rest, m, val) {

    out = ""
    rest = s

    while (match(rest, /&[#a-zA-Z0-9]+;/)) {

        out = out substr(rest, 1, RSTART-1)

        m = substr(rest, RSTART, RLENGTH)

        if (m ~ /^&#[0-9]+;$/) {
            val = sprintf("%c", substr(m, 3, length(m)-3))
        }
        else if (m ~ /^&#x[0-9a-fA-F]+;$/) {
            val = sprintf("%c", strtonum("0x" substr(m, 4, length(m)-4)))
        }
        else if (m in entity) {
            val = entity[m]
        }
        else {
            val = m
        }

        out = out val
        rest = substr(rest, RSTART + RLENGTH)
    }

    return out rest
}
